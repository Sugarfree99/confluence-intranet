# Confluence Configuration
CONFLUENCE_BASE_URL=https://nordrest.atlassian.net
CONFLUENCE_USERNAME=your-confluence-email@example.com
CONFLUENCE_API_TOKEN=your-api-token

# Space to sync
CONFLUENCE_SPACE_KEY=NORDREST

# Database Configuration (defaults match docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=confluence_mirror
DB_USER=postgres
DB_PASSWORD=postgres

# Server Configuration
PORT=3000
NODE_ENV=development

# Sync Configuration
SYNC_INTERVAL_MINUTES=60

# Security
JWT_SECRET=your-super-secret-key-change-in-production

# AI Services (Optional)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=model-name

# Logging
LOG_LEVEL=info
